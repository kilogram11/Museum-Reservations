/* 页面背景灰白色，突出卡片 */
page {
  background-color: #f9f5ec;
}

.container {
  padding: 30rpx;
}

/* 卡片容器 */
.notice-card {
  background-color: #efe6d8;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.03); /* 轻微阴影 */
  border: none;
}

/* 标题样式 */
.card-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #6b5a3e;
  margin-bottom: 16rpx;
}

/* 摘要样式 */
.card-summary {
  font-size: 28rpx;
  color: #8a7a63;
  line-height: 1.6;
  margin-bottom: 24rpx;
  /* 限制最多显示3行，超出省略，保持列表整洁 */
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
}

/* 日期样式 */
.card-date {
  font-size: 24rpx;
  color: rgba(107, 90, 62, 0.6);
  display: flex;
  align-items: center;
}

.icon {
  margin-right: 10rpx;
}
