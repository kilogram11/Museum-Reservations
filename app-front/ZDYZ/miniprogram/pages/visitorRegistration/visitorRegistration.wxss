page {
  background-color: #f9f5ec;
}
.container {
  padding: 30rpx;
}

.card {
  background: #efe6d8;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.05);
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 24rpx;
  color: #6b5a3e;
}

.input-group {
  margin-bottom: 20rpx;
}

.input-field {
  background: #fff;
  height: 80rpx;
  padding: 0 20rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #6b5a3e;
}

.face-auth-box {
  background: #f9f5ec;
  padding: 20rpx;
  text-align: center;
  border-radius: 8rpx;
  margin-bottom: 30rpx;
  border: 1px dashed #6b5a3e;
}
.face-text {
  color: #6b5a3e;
  font-size: 28rpx;
  opacity: 0.8;
}
.face-text.success {
  color: #07c160;
  border-color: #07c160;
}

.add-bar {
  margin-bottom: 30rpx;
}
.btn-add-main {
  background: rgba(139, 0, 0, 0.8);
  color: #fff;
  border-radius: 40rpx;
  font-size: 30rpx;
}

/* 弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}
.form-popup {
  width: 85%;
  margin-bottom: 0;
  position: relative;
  animation: slideUp 0.3s ease-out;
}
@keyframes slideUp {
  from {
    transform: translateY(100rpx);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}
.close-icon {
  font-size: 50rpx;
  color: #999;
  line-height: 1;
  padding: 10rpx;
}

.btn-primary {
  background-color: rgba(139, 0, 0, 0.8);
  color: #fff;
  font-weight: bold;
  border-radius: 10rpx;
}

/* 列表样式 */
.visitor-item {
  border-bottom: 1px solid #eee;
  padding: 20rpx 0;
  display: flex;
  justify-content: space-between;
}
.v-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #6b5a3e;
}
.v-detail {
  font-size: 26rpx;
  color: #8a7a63;
  margin-top: 4rpx;
}
.blacklist-tag {
  font-size: 24rpx;
  color: #d9534f;
  margin-top: 10rpx;
  background: #fdecea;
  display: inline-block;
  padding: 4rpx 8rpx;
  border-radius: 4rpx;
}

.visitor-actions {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 20rpx;
  font-size: 28rpx;
}
.action-btn.edit {
  color: rgba(139, 0, 0, 0.8);
}
.action-btn.delete {
  color: #d9534f;
}

/* 模拟人脸弹窗 */
.face-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}
.face-content {
  background: #fff;
  width: 500rpx;
  padding: 40rpx;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.face-scan-area {
  width: 200rpx;
  height: 200rpx;
  background: #ddd;
  border-radius: 50%;
  margin-bottom: 20rpx;
}
