/* pages/identify/identify.wxss */
.container {
  padding: 30rpx;
  background-color: #f9f5ec;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

.header-box {
  margin-bottom: 40rpx;
  text-align: center;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.desc {
  font-size: 28rpx;
  color: #888;
}

.image-box {
  background-color: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 40rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 500rpx;
  transition: all 0.3s ease;
}

.image-box.has-result {
  min-height: 400rpx;
}

.preview-img {
  width: 100%;
  height: 500rpx;
}

.placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 500rpx;
  background-color: #e9e9e9;
}

.icon-camera {
  width: 100rpx;
  height: 100rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.placeholder text {
  color: #999;
  font-size: 30rpx;
}

.footer-action {
  margin-top: auto;
  padding-bottom: 50rpx;
}

.btn-capture {
  background-color: #8b0000;
  color: #fff;
  border-radius: 50rpx;
  height: 100rpx;
  font-size: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 20rpx rgba(139, 0, 0, 0.3);
}

.result-box {
  background-color: #fff;
  padding: 30rpx;
  border-radius: 20rpx;
  animation: slideUp 0.5s ease;
}

.result-title {
  font-size: 38rpx;
  font-weight: bold;
  color: #8b0000;
  margin-bottom: 20rpx;
  text-align: center;
  border-bottom: 2rpx solid #eee;
  padding-bottom: 20rpx;
}

.result-content {
  font-size: 30rpx;
  color: #333;
  line-height: 1.8;
  margin-bottom: 40rpx;
  text-align: justify;
}

.btn-retry {
  background-color: #fff;
  color: #8b0000;
  border: 2rpx solid #8b0000;
  border-radius: 44rpx;
  font-size: 30rpx;
}

@keyframes slideUp {
  from {
    transform: translateY(50rpx);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}
