page {
  background-color: #f9f5ec; /* 米黄背景 */
  height: 100%;
}

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  padding-bottom: 20rpx;
}

.chat-list {
  flex: 1;
  padding: 30rpx; /* 增加边距 */
  box-sizing: border-box;
  overflow-y: auto;
  padding-bottom: 140rpx; /* 避免遮挡输入框 */
}

.message-item {
  display: flex;
  margin-bottom: 40rpx; /* 增加间距 */
  align-items: flex-start;
}

.user-message {
  flex-direction: row-reverse;
}

.bot-message {
  flex-direction: row;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%; /* 圆形头像 */
  margin: 0 20rpx;
  background-color: #fff;
  border: 2rpx solid #c8bba3; /* 头像边框 */
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.content {
  max-width: 65%;
  padding: 24rpx 32rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-all;
  position: relative;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.05); /* 轻微阴影 */
}

/* AI 消息样式 - 深米色卡片 */
.bot-message .content {
  background-color: #efe6d8;
  color: #5a4626; /* 深褐文字 */
  border-top-left-radius: 4rpx; /* 气泡角效果 */
}

/* 用户消息样式 - 故宫红 */
.user-message .content {
  background-color: #8b0000;
  color: #ffffff;
  border-top-right-radius: 4rpx; /* 气泡角效果 */
}

/* 输入区域 */
.input-area {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  min-height: 120rpx; /* 增高输入区 */
  background-color: #f9f5ec; /* 与页面背景一致 */
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  box-sizing: border-box;
  border-top: 1rpx solid #e0d0b0; /* 分割线 */
  z-index: 100;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom)); /* 适配全面屏 */
}

.input-box {
  flex: 1;
  height: 80rpx;
  background-color: #ffffff;
  border: 1rpx solid #c8bba3; /* 边框 */
  border-radius: 40rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
  margin-right: 20rpx;
  color: #333;
}

.send-btn {
  width: 140rpx;
  height: 80rpx;
  line-height: 80rpx;
  background-color: #8b0000; /* 故宫红 */
  color: #fff;
  font-size: 28rpx;
  padding: 0;
  border-radius: 40rpx; /* 圆角按钮 */
  text-align: center;
  font-weight: bold;
  box-shadow: 0 4rpx 10rpx rgba(139, 0, 0, 0.3);
}

.send-btn[disabled] {
  background-color: #d1c0a5; /* 禁用态颜色 */
  color: #f0f0f0;
  box-shadow: none;
}
