page {
  background-color: #f9f5ec;
}

.container {
  padding: 40rpx 30rpx;
}

/* 标题区域 */
.title {
  font-size: 42rpx;
  font-weight: bold;
  color: #6b5a3e;
  margin-bottom: 20rpx;
  line-height: 1.4;
}

.meta {
  font-size: 26rpx;
  color: #8a7a63;
  margin-bottom: 30rpx;
}

.divider {
  margin: 0 10rpx;
}

.line {
  height: 1px;
  background-color: rgba(107, 90, 62, 0.2);
  margin-bottom: 40rpx;
}

/* 正文区域 */
.content {
  margin-bottom: 60rpx;
}

.detail-text {
  font-size: 32rpx;
  color: #6b5a3e;
  line-height: 1.8;
  /* 关键：保留数据中的换行符和空格 */
  white-space: pre-wrap;
  text-align: justify;
}

/* 底部落款 */
.footer {
  display: flex;
  flex-direction: column;
  align-items: flex-end; /* 靠右对齐 */
  margin-top: 40rpx;
  padding-bottom: 40rpx;
}

.footer-org {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.footer-date {
  font-size: 28rpx;
  color: #8a7a63;
}
