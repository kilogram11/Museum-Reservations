<view class="profile-container">
  <!-- 已登录状态（匹配原型图2） -->
  <view wx:if="{{isLogin}}">
    <!-- 头像区域：添加bindtap跳转到编辑页 -->
    <view class="user-header" bindtap="goToEditProfile">
      <!-- 用emoji显示头像（匹配原型） -->
      <image class="avatar-img" src="{{userInfo.avatarUrl || '/images/avatars/1.png'}}" mode="aspectFill"></image>
      <view class="user-info">
        <text class="user-name">{{userInfo.name}}</text>
        <text class="edit-tip">点击编辑个人信息</text>
      </view>
    </view>

    <!-- 我的订单卡片 -->
    <view class="order-card-section">
      <view class="section-header" bindtap="goToOrderRecord" data-tab="0">
        <text class="section-title">我的订单</text>
        <view class="section-more">
          <text>查看全部</text>
          <image src="/images/arrow.svg" class="arrow-icon-small" style="margin-left:4rpx;"></image>
        </view>
      </view>
      
      <view class="order-grid">
        <view class="grid-item" bindtap="goToOrderRecord" data-tab="1">
          <image src="/images/icons/wait.png" class="grid-icon"></image>
          <text class="grid-text">待使用</text>
        </view>
        <view class="grid-item" bindtap="goToOrderRecord" data-tab="2">
          <image src="/images/icons/used.png" class="grid-icon"></image>
          <text class="grid-text">已核销</text>
        </view>
        <view class="grid-item" bindtap="goToOrderRecord" data-tab="3">
          <image src="/images/icons/refund.png" class="grid-icon"></image>
          <text class="grid-text">退款/售后</text>
        </view>
        <view class="grid-item" bindtap="goToMessage">
          <view class="icon-wrap">
            <image src="/images/icons/msg.png" class="grid-icon"></image>
            <view class="badge-dot" wx:if="{{unreadCount > 0}}"></view>
          </view>
          <text class="grid-text">我的消息</text>
        </view>
      </view>
    </view>

    <!-- 我的服务卡片 -->
    <view class="menu-card">
      <view class="card-title">我的服务</view>

      <view class="menu-list-item" bindtap="goToVisitorReg">
        <view class="menu-left">
          <image src="/images/icons/book_person.png" class="menu-icon-img"></image>
          <text class="menu-text">预约人登记</text>
        </view>
        <image src="/images/arrow.svg" class="arrow-icon"></image>
      </view>

      <view class="menu-list-item" bindtap="goToEditProfile">
        <view class="menu-left">
          <image src="/images/icons/setting.png" class="menu-icon-img"></image>
          <text class="menu-text">账号设置</text>
        </view>
        <image src="/images/arrow.svg" class="arrow-icon"></image>
      </view>

      <view class="menu-list-item" bindtap="goToPrivacy">
        <view class="menu-left">
          <image src="/images/icons/private.png" class="menu-icon-img"></image>
          <text class="menu-text">隐私说明</text>
        </view>
        <image src="/images/arrow.svg" class="arrow-icon"></image>
      </view>

      <view class="menu-list-item" bindtap="goToFaq">
        <view class="menu-left">
          <image src="/images/icons/Q&A.png" class="menu-icon-img"></image>
          <text class="menu-text">常见问题</text>
        </view>
        <image src="/images/arrow.svg" class="arrow-icon"></image>
      </view>
    </view>

    <view class="btn-red" bindtap="logout">
      [→ 退出登录
    </view>
  </view>

  <!-- 未登录状态（匹配原型图2） -->
  <view wx:else>
    <view class="unlogin-tip">
      <text class="unlogin-text">未登录</text>
      <text class="login-btn" bindtap="goToLogin">点击登录后查看个人信息</text>
    </view>

    <!-- 我的服务卡片 (未登录) -->
    <view class="menu-card">
      <view class="card-title">我的服务</view>

      <view class="menu-list-item" bindtap="goToVisitorReg">
        <view class="menu-left">
          <image src="/images/icons/book_person.png" class="menu-icon-img"></image>
          <text class="menu-text">预约人登记</text>
        </view>
        <image src="/images/arrow.svg" class="arrow-icon"></image>
      </view>
      
      <view class="menu-list-item" bindtap="goToOrderRecord">
        <view class="menu-left">
          <icon type="calendar" size="24" color="#8B0000"/>
          <text class="menu-text">预约记录</text>
        </view>
        <image src="/images/arrow.svg" class="arrow-icon"></image>
      </view>
    </view>
  </view>

  <text class="version" wx:if="{{isLogin}}">当前版本: 2.4.12</text>
</view>