/* 全局宣纸背景+字体 */
page {
  background-color: #f5f0e8;
  font-family: "KaiTi", "STKaiti", serif;
}

/* 原型中的红色按钮样式 */
.btn-red {
  width: 80%;
  height: 80rpx;
  line-height: 80rpx;
  background-color: #8B0000;
  color: #fff;
  border-radius: 10rpx;
  text-align: center;
  font-size: 32rpx;
  margin: 30rpx auto;
}

/* 标题样式（匹配原型的楷体+红色） */
.title-level1 {
  font-size: 48rpx;
  font-weight: bold;
  color: #8B0000;
  text-align: center;
}
.title-level2 {
  font-size: 36rpx;
  color: #8B0000;
}
.title-level3 {
  font-size: 32rpx;
  color: #8B4513;
}